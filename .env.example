# ============================================================================
# Environment Variables for Docker Compose Setup
# ============================================================================
#
# Copy this file to .env-mongo and fill in your values
#
# cp .env.example .env-mongo
#
# This file contains environment variables used by both the docker-compose
# setup and the original build scripts.
#
# ============================================================================

# ============================================================================
# MongoDB Admin Credentials
# These credentials are used to create the root admin user
# ============================================================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin-password

# ============================================================================
# MongoDB Application Credentials
# These credentials are used for application-level database access
# ============================================================================
MONGO_APP_USER=app_user
MONGO_APP_PASSWORD=app-password
MONGO_APP_DB=app_db

# ============================================================================
# MongoDB Connection Details
# These are the connection endpoints for the MongoDB cluster
# ============================================================================
MONGO_ROUTER_HOST=192.168.100.4
MONGO_ROUTER_PORT=27020
MONGO_CONFIG_HOST=192.168.100.4
MONGO_CONFIG_PORT=27019

# ============================================================================
# OS-Ken Controller Ports
# Port numbers for the SDN controllers
# ============================================================================
OSKEN1_PORT=6653
OSKEN2_PORT=6654

# ============================================================================
# Network Configuration (for network setup script)
# Advanced networking parameters - modify only if you understand the topology
# ============================================================================

# Internet uplink configuration between host and NAT router
INTERNET_LINK_HOST_IP=172.20.0.1/30
INTERNET_LINK_ROUTER_IP=172.20.0.2/30
INTERNET_LINK_GW=172.20.0.1

# Host uplink interface for NAT/masquerading
# Auto-detected by default, but can be overridden
DEFAULT_UPLINK_IF=enp0s3

# ============================================================================
# Optional: Python Environment
# ============================================================================
PYTHONUNBUFFERED=1
