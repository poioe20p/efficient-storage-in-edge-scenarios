# ============================================================================
# WAN emulation knobs for the inter-LAN router (nat-router eth1/eth2).
# Sourced by source/scripts/build_network_setup.sh and consumed by
# source/scripts/network/inject_wan_latency.sh (called from build_router.sh).
#
# Same-LAN traffic stays inside its OVS bridge and is not affected.
#
# Profile presets (RTT in ms):
#   lab               WAN_RTT_MS=0     # no emulation, raw veth latency
#   metro (default)   WAN_RTT_MS=10    # same-city edge â†” edge
#   regional          WAN_RTT_MS=40    # cross-region within continent
#   inter-continental WAN_RTT_MS=150   # trans-oceanic worst case
#
# The metro default (10 ms RTT, +5 ms one-way per leg) is calibrated against
# the standard phases.json workload: it lifts cross_region_hotspot peer p95
# from ~50 ms to ~75 ms (above TAU_DADOS_MS=65 ms so the breach gate fires)
# while only nudging compute-tier t_total by ~5 ms â€” not enough to spuriously
# trigger compute scale-up during storage_stress / cross_region_hotspot.
# ============================================================================

# Symmetric round-trip latency between LAN1 and LAN2, in milliseconds.
# Half is applied on each of the router's eth1 (LAN1) and eth2 (LAN2)
# egress queues, so RTT â‰ˆ WAN_RTT_MS.
WAN_RTT_MS=${WAN_RTT_MS:-10}

# Optional jitter on top of one-way delay (ms). 0 = deterministic delay.
WAN_JITTER_MS=0

# Optional packet loss percentage (0â€“100). 0 = lossless.
WAN_LOSS_PCT=0

# Optional egress bandwidth cap in kbit. 0 = uncapped.
WAN_RATE_KBIT=0
