# RQ1 instrumentation verification — same as current_state_integrated.env
# but with shorter scale-down cooldown so scale-down fires within the
# 480 s experiment window.
STORAGE_PERSISTENT_RESERVE_ENABLED=1
SS_ENABLED=1
MAX_DYNAMIC_STORAGE=5
MAX_DYNAMIC_COMPUTE=6
SCALEUP_STORAGE_BASE_THRESHOLD=0.12
SCALEUP_COMPUTE_BASE_THRESHOLD=0.20
SCALEUP_CPU_FLOOR=3
SCALEUP_T_PROC_FLOOR=15
# Shorter cooldown so scale-down fires within the 480 s run window
# (golden value 180 is too long for a 2 min demand_drop phase).
SCALEDOWN_COMPUTE_COOLDOWN_S=60
SCALE_DOWN_COMPUTE_REQUIRED=9
SCALEUP_W_STORAGE_CPU=0.60
SCALEUP_W_T_DB=0.40
SCALEUP_STORAGE_CPU_FLOOR=1.5
SCALEUP_STORAGE_CPU_SPAN=5
SCALEUP_T_DB_FLOOR=60
SCALEUP_T_DB_SPAN=250
SCALEUP_STORAGE_REQUIRED=2
SCALEUP_STORAGE_WINDOW_SIZE=5
SCALEUP_STORAGE_COOLDOWN_S=120
