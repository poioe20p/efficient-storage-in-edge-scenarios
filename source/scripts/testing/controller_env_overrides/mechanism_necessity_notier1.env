# Mechanism necessity ablation — Tier 1 selective-sync disabled (Run D).
STORAGE_PERSISTENT_RESERVE_ENABLED=1
SS_ENABLED=0
MAX_DYNAMIC_STORAGE=5
MAX_DYNAMIC_COMPUTE=6
# Storage trigger — t10 (activates at CLIENTS=8; t12 does not)
SCALEUP_STORAGE_BASE_THRESHOLD=0.10
SCALEUP_STORAGE_COOLDOWN_S=120
# Storage scale-down cooldown extended to 300s — prevents reserve cycling
# during the 240s storage_hotspot phase (300 > 240, so scale-down never fires).
SCALEDOWN_STORAGE_COOLDOWN_S=300
SCALEUP_W_STORAGE_CPU=0.60
SCALEUP_W_T_DB=0.40
SCALEUP_STORAGE_CPU_FLOOR=1.5
SCALEUP_STORAGE_CPU_SPAN=5
SCALEUP_T_DB_FLOOR=60
SCALEUP_T_DB_SPAN=250
SCALEUP_STORAGE_REQUIRED=2
SCALEUP_STORAGE_WINDOW_SIZE=5
# Compute trigger — golden config values
SCALEUP_COMPUTE_BASE_THRESHOLD=0.20
SCALEUP_CPU_FLOOR=3
SCALEUP_T_PROC_FLOOR=15
SCALEDOWN_COMPUTE_COOLDOWN_S=180
SCALE_DOWN_COMPUTE_REQUIRED=9
