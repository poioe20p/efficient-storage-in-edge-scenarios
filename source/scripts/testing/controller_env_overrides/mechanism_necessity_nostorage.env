# Mechanism necessity ablation — storage scale-up disabled (Run C).
# MAX_DYNAMIC_STORAGE=0 blocks ALL dynamic storage paths:
#   - Reserve pre-preparation (STORAGE_PERSISTENT_RESERVE_ENABLED=0)
#   - Direct DataAlert spawn (scaling_policy.py:248: dynamic_storage_count >= 0 → skip)
# The single fixed MongoDB per LAN handles all reads.
STORAGE_PERSISTENT_RESERVE_ENABLED=0
MAX_DYNAMIC_STORAGE=0
SS_ENABLED=1
MAX_DYNAMIC_COMPUTE=6
# Storage trigger — t10 (threshold values kept for consistency; reserve path off)
SCALEUP_STORAGE_BASE_THRESHOLD=0.10
SCALEUP_STORAGE_COOLDOWN_S=60
# Storage scale-down cooldown extended to 300s — kept for consistency
# (no dynamic storage nodes exist with MAX_DYNAMIC_STORAGE=0, so this is inert).
SCALEDOWN_STORAGE_COOLDOWN_S=300
SCALEUP_W_STORAGE_CPU=0.60
SCALEUP_W_T_DB=0.40
SCALEUP_STORAGE_CPU_FLOOR=1.5
SCALEUP_STORAGE_CPU_SPAN=5
SCALEUP_T_DB_FLOOR=60
SCALEUP_T_DB_SPAN=250
SCALEUP_STORAGE_REQUIRED=2
SCALEUP_STORAGE_WINDOW_SIZE=5
# Compute trigger — golden config values
SCALEUP_COMPUTE_COOLDOWN_S=20
SCALEUP_COMPUTE_BASE_THRESHOLD=0.20
SCALEUP_CPU_FLOOR=3
SCALEUP_T_PROC_FLOOR=15
SCALEDOWN_COMPUTE_COOLDOWN_S=180
SCALE_DOWN_COMPUTE_REQUIRED=9
VIP_HARD_TIMEOUT=30
