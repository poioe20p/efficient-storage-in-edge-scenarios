      "mix": {
        "device_status": 0.80,
        "dashboard": 0.10,
        "service_pressure": 0.10
      }
    },
    {
      "name": "reverse_hotspot",
      "duration_s": 300,
      "rate_per_client": 8.0,
      "cross_region_ratio": 0.85,
      "hotspot_direction": "lan1_to_lan2",
      "mix": {
        "device_status": 0.80,
        "dashboard": 0.10,
        "service_pressure": 0.10
      }
    },
    {
      "name": "compute_ramp",
      "duration_s": 120,
