      "mix": {
        "device_status": 0.35,
        "dashboard": 0.35,
        "service_pressure": 0.30
      }
    },
    {
      "name": "storage_stress",
      "duration_s": 240,
      "rate_per_client": 7.0,
      "cross_region_ratio": 0.5,
