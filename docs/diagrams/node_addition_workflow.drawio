                <mxCell id="t2_recv" value="&lt;b&gt;ZMQ SUB&lt;/b&gt;&lt;br&gt;Receive TelemetrySummary&lt;br&gt;from Aggregator (every ~10 s)&lt;div&gt;Controlador recebe a informação agregada pelo Container Aggregator (de cada rede) por potrocolo PUB/SUB&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="670" y="140" width="260" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="t2_compute" value="&lt;b&gt;Compute T_proc&lt;/b&gt;&lt;br&gt;T_proc = T_total − T_dados" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="670" y="260" width="260" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="state_box" value="&lt;b&gt;In-Memory State&lt;/b&gt;&lt;br&gt;_latest[network_id]&lt;br&gt;• avg_T_proc_ms&lt;br&gt;• avg_T_dados_ms&lt;br&gt;• topology (MACs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="370" y="200" width="235" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="t1_loop" value="&lt;b&gt;Packet-In Event Loop&lt;/b&gt;&lt;br&gt;WSM Cost formula:&lt;br&gt;Cost_j = θ·(T_proc,j / T_proc,max) + (1−θ)·(Hops_j / Hops,max)&lt;br&gt;→ Install DNAT/SNAT OpenFlow rule&lt;br&gt;→ Packet-Out&lt;div&gt;Essencialmente para cada pedido HTTP para o VIP_SERVER o servidor é escolhido com base numa função de custo&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="45" y="190" width="280" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="infra_agg" value="&lt;b&gt;Container Aggregator (per network)&lt;/b&gt;&lt;br&gt;PULL :5555 / PUB :5556&lt;br&gt;10 s windowed summary&lt;br&gt;→ TelemetrySummary JSON&lt;div&gt;Recebe telemetria de todos os servidores e nós do mongodb na sua rede&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="175" width="260" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="infra_ovs" value="&lt;b&gt;OVS Switch&lt;/b&gt;&lt;br&gt;OpenFlow DNAT/SNAT rules&lt;br&gt;VIP_Web  |  VIP_Dados" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
