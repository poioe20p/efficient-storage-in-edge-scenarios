                </mxCell>
                <mxCell id="ovs_arp_data" value="&lt;b&gt;ARP Proactive Rule&lt;/b&gt;&lt;br&gt;match: arp_tpa = 10.0.X.254&lt;br&gt;action: ARP Reply, dl_src = VIP_DATA_MAC&lt;br&gt;&lt;i&gt;installed on switch connect — no controller&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
