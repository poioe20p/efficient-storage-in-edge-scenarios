                </mxCell>
                <mxCell id="ovs_punt_web" value="&lt;b&gt;Punt Rule — priority 100&lt;/b&gt;&lt;br&gt;match: eth_type=0x0800, nw_dst=10.0.0.253&lt;br&gt;action: OUTPUT:CONTROLLER (Packet-In)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="520" y="280" width="270" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="ovs_dnat_web" value="&lt;b&gt;DNAT + SNAT Rules — priority 200&lt;/b&gt;&lt;br&gt;DNAT: nw_dst=10.0.0.253 → set(nw_dst=ws_ip, eth_dst=ws_mac), out→ws_port&lt;br&gt;SNAT: nw_src=ws_ip → set(nw_src=10.0.0.253, eth_src=VIP_WEB_MAC), out→client_port&lt;br&gt;&lt;i&gt;installed reactively by Thread 1 after Packet-In&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
