                </mxCell>
                <mxCell id="client_web" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;IP: 10.0.0.2&lt;br&gt;(any src port)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="55" y="296" width="190" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="client_data" value="&lt;b&gt;Web Server&lt;/b&gt;&lt;br&gt;(acting as MongoDB client)&lt;br&gt;IP: 10.0.0.4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#b71c1c;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="40" y="773.5" width="190" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="ctrl_web" value="&lt;b&gt;SDN Controller — Thread 1&lt;/b&gt;&lt;br&gt;VipRoutingMixin.handle_vip_server( )&lt;br&gt;&lt;br&gt;WSM cost function:&lt;br&gt;cost_j = θ · (T_proc,j / T_proc,max)&lt;br&gt;         + (1−θ) · (Hops_j / Hops,max)&lt;br&gt;&lt;br&gt;→ select lowest-cost web server&lt;br&gt;→ install DNAT+SNAT + Packet-Out" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1565c0;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="144" width="285" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="ctrl_data" value="&lt;b&gt;SDN Controller — Thread 1&lt;/b&gt;&lt;br&gt;VipRoutingMixin.handle_vip_data( )&lt;br&gt;&lt;br&gt;MDVBP Tier Map:&lt;br&gt;  Tier 0 → Primary (home network)&lt;br&gt;  Tier 1 → Selective Sync Node (hot subset + TTL)&lt;br&gt;  Tier 2 → Full Secondary (oplog replica)&lt;br&gt;&lt;br&gt;→ route to active tier for src domain&lt;br&gt;→ install DNAT+SNAT + Packet-Out" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1565c0;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
