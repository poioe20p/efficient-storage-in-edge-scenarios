    <diagram id="content-discovery-platform" name="Content Discovery Platform Overview">
        <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="950" background="#ffffff" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
