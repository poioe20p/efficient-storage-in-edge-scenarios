                <!-- ===== TITLE ===== -->
                <mxCell id="title" value="Content Discovery Platform — SDN-Orchestrated Edge Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="350" y="15" width="1100" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Users access regionally hosted content via auto-scaled edge servers. Hot content is selectively cached close to consumers; cold content is served cross-region." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#555555;" parent="1" vertex="1">
