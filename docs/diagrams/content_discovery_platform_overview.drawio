                    <mxGeometry x="820" y="635" width="160" height="30" as="geometry"/>
                </mxCell>

                <!-- ===== TIER 1 SELECTIVE SYNC ===== -->
                <mxCell id="tier1_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" parent="1" vertex="1">
                    <mxGeometry x="550" y="690" width="700" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="tier1_label" value="&lt;b&gt;Tier 1 — Selective Sync&lt;/b&gt;  &lt;span style=&quot;font-size:10px;color:#888&quot;&gt;(hot-content cache)&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="570" y="695" width="400" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="tier1_desc" value="&lt;span style=&quot;font-size:10px&quot;&gt;Standalone mongod in the consumer LAN, seeded with only the hot subset of documents&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;being read cross-region. One Change Stream per hot collection keeps the node current.&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Edge servers short-circuit eligible point reads to the local Tier 1 node;&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px&quot;&gt;cold reads and all writes fall through to VIP_DATA as normal.&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="570" y="720" width="660" height="80" as="geometry"/>
                </mxCell>

                <!-- ===== RESERVE NOTE ===== -->
                <mxCell id="reserve_note" value="&lt;b&gt;Storage Reserve&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Pre-warmed standby secondaries&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;ready for instant activation&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="90" y="830" width="180" height="55" as="geometry"/>
                </mxCell>

