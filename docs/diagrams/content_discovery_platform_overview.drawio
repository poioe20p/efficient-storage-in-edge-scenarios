                </mxCell>
                <mxCell id="controller_label" value="&lt;b style=&quot;font-size:14px;&quot;&gt;SDN Controller  (OS-Ken / OpenFlow)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;" parent="1" vertex="1">
