                <mxCell id="lane_backend_hdr" value="&lt;b&gt;MongoDB storage node(s)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#6b1a1a&quot;&gt;VIP_DATA_N1 pool — LAN 1 replica set&lt;br/&gt;VIP_DATA_N2 pool — LAN 2 replica set&lt;br/&gt;SECONDARY only · PRIMARY never elected&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="25" y="1010" width="200" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="n_domain_pick" value="&lt;b&gt;Domain routing at edge_server&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;_id prefix &quot;lan1::…&quot; → VIP_DATA_N1&lt;br/&gt;_id prefix &quot;lan2::…&quot; → VIP_DATA_N2&lt;br/&gt;partitioned device docs, no cross-RS queries&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#6c8ebf;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="150" width="280" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_client_arp" value="&lt;b&gt;ARP WHO-HAS&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;arp_tpa = VIP_DATA_N{k}_IP&lt;br/&gt;triggered by first Mongo operation&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="270" y="235" width="280" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_arp_punt" value="&lt;b&gt;ARP punt rule&lt;/b&gt; (prio 100)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_type=0x0806, arp_tpa=VIP_DATA_N{k}_IP&lt;br/&gt;→ output: CONTROLLER&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="290" y="382.5" width="280" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_reply_arp" value="&lt;b&gt;_reply_vip_arp()&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;craft ARP reply&lt;br/&gt;sha = VIP_DATA_N{k}_MAC&lt;br/&gt;spa = VIP_DATA_N{k}_IP&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="750" width="280" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_snoop" value="&lt;b&gt;snoop_arp()&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;learn edge_server IP ↔ MAC&lt;br/&gt;_ip_to_mac · _mac_to_ip&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="270" y="875" width="280" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_client_syn" value="&lt;b&gt;TCP SYN&lt;/b&gt; (MongoDB handshake, port 27017)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_dst = VIP_DATA_N{k}_MAC&lt;br/&gt;ipv4_dst = VIP_DATA_N{k}_IP&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="610" y="200" width="300" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_vip_punt" value="&lt;b&gt;VIP punt rule&lt;/b&gt; (prio 100)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_type=0x0800, ipv4_dst=VIP_DATA_N{k}_IP&lt;br/&gt;ip_proto ∈ {1, 6, 17}&lt;br/&gt;→ output: CONTROLLER&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="610" y="405" width="300" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_handle_vip" value="&lt;b&gt;handle_vip_packet_in()&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;match ipv4_dst == VIP_DATA_N1_IP → domain=&quot;n1&quot;&lt;br/&gt;              == VIP_DATA_N2_IP → domain=&quot;n2&quot;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="520" y="640" width="300" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_select" value="&lt;b&gt;select_storage(domain, client_mac)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;iterate vip_storage_pool_n{domain} &lt;b&gt;(SECONDARY only)&lt;/b&gt;&lt;br/&gt;read _storage_stats (written by Thread 2)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="960" y="615" width="300" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_cost" value="&lt;b&gt;WSM cost function (5 terms)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Cost_j = W_CPU·CPÛ + W_RAM·RAM̂&lt;br/&gt;       + W_CONN·Connm̂ + W_LAG·Lag̃&lt;br/&gt;       + W_HOPS·Hopŝ&lt;br/&gt;defaults: 0.2 / 0.2 / 0.1 / 0.2 / 0.3&lt;br/&gt;unknown stats → 1.0 (worst case)&lt;br/&gt;ties → per-domain round-robin counter&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="730" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="n_hops" value="&lt;b&gt;Hops estimation&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px;text-align:left&quot;&gt;hop_cache ▸&lt;br/&gt;local no path →&lt;br/&gt;  max(_avg_hop, 1.0) ▸&lt;br/&gt;cross-LAN →&lt;br/&gt;  local + _peer_avg_hop ▸&lt;br/&gt;unknown → hops_max&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="700" width="110" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="n_install" value="&lt;b&gt;_install_vip_dnat_snat()&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;install flow pair (prio 200)&lt;br/&gt;idle=VIP_IDLE_TIMEOUT (30 s) · hard=VIP_HARD_TIMEOUT (120 s)&lt;br/&gt;&lt;b&gt;source port omitted&lt;/b&gt; → one rule covers all concurrent MongoClient connections&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1575" y="860" width="425" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_dnat_rule" value="&lt;b&gt;DNAT rule&lt;/b&gt; (prio 200)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;match: eth_src=client_mac, eth_dst=VIP_DATA_N{k}_MAC,&lt;br/&gt;ipv4_src=client_ip, ipv4_dst=VIP_DATA_N{k}_IP, ip_proto&lt;br/&gt;actions: set_field(eth_dst=storage_mac, ipv4_dst=storage_ip),&lt;br/&gt;output=storage_port&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="955" y="357.5" width="425" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="n_snat_rule" value="&lt;b&gt;SNAT rule&lt;/b&gt; (prio 200, reverse)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;match: eth_src=storage_mac (or ROUTER_MAC), eth_dst=client_mac,&lt;br/&gt;ipv4_src=storage_ip, ipv4_dst=client_ip, ip_proto&lt;br/&gt;actions: set_field(eth_src=VIP_DATA_N{k}_MAC, ipv4_src=VIP_DATA_N{k}_IP),&lt;br/&gt;output=client_port&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="940" y="460" width="425" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="n_first_po" value="&lt;b&gt;Packet-Out (first packet)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;apply DNAT actions to in-flight packet — Mongo handshake proceeds&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="890" width="425" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="n_client_req" value="&lt;b&gt;subsequent Mongo ops&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;same MongoClient socket — find/insert/update/getMore&lt;br/&gt;source port varies (omitted from flow match)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1410" y="170" width="320" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="n_ovs_match" value="&lt;b&gt;flow hit (prio 200)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;DNAT/SNAT applied in datapath · controller bypassed&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1970" y="397.5" width="320" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n_localhop" value="&lt;b&gt;Same-LAN SECONDARY&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_dst = storage_mac&lt;br/&gt;output via get_next_hop_port&lt;br/&gt;(fallback host_attachment)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="2000" y="1000" width="155" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_crosshop" value="&lt;b&gt;Peer-LAN SECONDARY&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_dst = &lt;b&gt;ROUTER_MAC&lt;/b&gt;&lt;br/&gt;output = ROUTER_OVS_PORT&lt;br/&gt;→ inter-LAN router (L3 hop)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="2165" y="1000" width="155" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_return_note" value="&lt;b&gt;return path&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;SECONDARY → OVS → SNAT rule rewrites&lt;br/&gt;eth_src → VIP_DATA_N{k}_MAC&lt;br/&gt;ipv4_src → VIP_DATA_N{k}_IP&lt;br/&gt;→ edge_server sees the VIP as source&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf5ea;strokeColor=#4d8b4d;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1990" y="1150" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_idle" value="&lt;b&gt;MongoClient idle&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;no op for maxIdleTimeMS&lt;br/&gt;driver closes socket&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2490" y="200" width="180" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_timeout" value="&lt;b&gt;flow timeout&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;idle 30 s (aligned) / hard 120 s&lt;br/&gt;DNAT/SNAT rule evicted&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2490" y="390" width="180" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_resume_punt" value="&lt;b&gt;prio 100 punt rule resumes&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;next query → fresh TCP SYN → controller&lt;br/&gt;→ fresh WSM selection&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="2490" y="685" width="180" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="n_stats_feed" value="&lt;b&gt;_storage_stats&lt;/b&gt; (in-memory dict)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;CPU, RAM, connections_current, repl_lag_s,&lt;br/&gt;member_state (only SECONDARY pooled)&lt;br/&gt;written by Thread 2 (telemetry) → read here&lt;br/&gt;no lock (eventlet cooperative switching)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="580" y="730" width="300" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="n_pool" value="&lt;b&gt;vip_storage_pool_n1 / _n2&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px;color:#666&quot;&gt;per-domain in-memory dicts: mac → entry&lt;br/&gt;maintained by TopologyMixin / elasticity&lt;br/&gt;PRIMARY excluded (replica-set invariant)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="630" y="860" width="300" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="e_dom_arp" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;" parent="1" source="n_domain_pick" target="n_client_arp" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_arp_1" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;" parent="1" source="n_client_arp" target="n_arp_punt" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_arp_2" value="PacketIn" style="endArrow=classic;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=10;fontStyle=2;labelBackgroundColor=#ffffff;" parent="1" source="n_arp_punt" target="n_reply_arp" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_arp_3" value="PacketOut&#xa;(ARP reply)" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;fontStyle=2;labelBackgroundColor=#ffffff;" parent="1" source="n_reply_arp" target="n_client_arp" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="270" y="480"/>
                            <mxPoint x="270" y="340"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_snoop" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=1;dashed=1;" parent="1" source="n_reply_arp" target="n_snoop" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_syn_1" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;" parent="1" source="n_client_syn" target="n_vip_punt" edge="1">
