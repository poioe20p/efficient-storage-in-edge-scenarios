                <mxCell id="n_crosshop" value="&lt;b&gt;Cross-LAN backend&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_dst = &lt;b&gt;ROUTER_MAC&lt;/b&gt;&lt;br/&gt;output = ROUTER_OVS_PORT&lt;br/&gt;→ inter-LAN router (L3 hop)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1575" y="1010" width="155" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="n_return_note" value="&lt;b&gt;return path&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;backend → OVS → SNAT rule rewrites&lt;br/&gt;eth_src → VIP_SERVER_MAC&lt;br/&gt;ipv4_src → VIP_SERVER_IP&lt;br/&gt;→ client sees VIP as source&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf5ea;strokeColor=#4d8b4d;fontSize=10;" parent="1" vertex="1">
