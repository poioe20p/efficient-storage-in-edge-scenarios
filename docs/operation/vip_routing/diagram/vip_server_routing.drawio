                </mxCell>
                <mxCell id="n_handle_vip" value="&lt;b&gt;handle_vip_packet_in()&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;match ipv4_dst == VIP_SERVER_IP&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="570" y="495" width="300" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="n_select" value="&lt;b&gt;select_server(client_mac)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;iterate VIP_SERVER pool&lt;br/&gt;read _server_stats (written by Thread 2)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="970" y="490" width="300" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_cost" value="&lt;b&gt;WSM cost function&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Cost_j = W_CPU·CPÛ + W_RAM·RAM̂&lt;br/&gt;       + W_REQ·Req̂ + W_HOPS·Hopŝ&lt;br/&gt;defaults: 0.2 / 0.2 / 0.2 / 0.4&lt;br/&gt;unknown stats → 1.0 (worst case)&lt;br/&gt;ties → round-robin counter&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="980" y="640" width="300" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="n_hops" value="&lt;b&gt;Hops estimation&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px;text-align:left&quot;&gt;hop_cache (shortest path) ▸&lt;br/&gt;local no path → max(_avg_hop, 1.0) ▸&lt;br/&gt;cross-LAN → local + _peer_avg_hop ▸&lt;br/&gt;unknown → hops_max&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="1340" y="530" width="110" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="n_install" value="&lt;b&gt;_install_vip_dnat_snat()&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;install flow pair (prio 200)&lt;br/&gt;idle=VIP_IDLE_TIMEOUT (30 s)&lt;br/&gt;hard=VIP_HARD_TIMEOUT (120 s)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="960" y="800" width="420" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_dnat_rule" value="&lt;b&gt;DNAT rule&lt;/b&gt; (prio 200)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;match: eth_src=client_mac, eth_dst=VIP_SERVER_MAC,&lt;br/&gt;ipv4_src=client_ip, ipv4_dst=VIP_SERVER_IP, ip_proto&lt;br/&gt;actions: set_field(eth_dst=backend_mac, ipv4_dst=backend_ip),&lt;br/&gt;output=backend_port&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="950" y="290" width="420" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_snat_rule" value="&lt;b&gt;SNAT rule&lt;/b&gt; (prio 200, reverse)&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;match: eth_src=backend_mac(or ROUTER_MAC), eth_dst=client_mac,&lt;br/&gt;ipv4_src=backend_ip, ipv4_dst=client_ip, ip_proto&lt;br/&gt;actions: set_field(eth_src=VIP_SERVER_MAC, ipv4_src=VIP_SERVER_IP),&lt;br/&gt;output=client_port&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">
                    <mxGeometry x="950" y="385" width="420" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="n_first_po" value="&lt;b&gt;Packet-Out (first packet)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;apply DNAT actions to in-flight packet&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="960" y="920" width="420" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="n_client_req" value="&lt;b&gt;subsequent packets&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;same 5-tuple (source port omitted from match)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1410" y="175" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_ovs_match" value="&lt;b&gt;flow hit (prio 200)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;DNAT/SNAT applied in datapath · controller bypassed&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1410" y="302.5" width="320" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="n_localhop" value="&lt;b&gt;Local backend&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:9px&quot;&gt;eth_dst = backend_mac&lt;br/&gt;output via get_next_hop_port&lt;br/&gt;(fallback host_attachment)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" parent="1" vertex="1">
