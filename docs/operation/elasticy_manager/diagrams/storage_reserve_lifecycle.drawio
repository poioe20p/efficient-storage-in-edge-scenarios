<mxfile host="65bd71144e">
    <diagram id="storage-reserve-lifecycle" name="Storage Reserve Lifecycle">
        <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="900" background="#ffffff" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <!-- Title -->
                <mxCell id="title" value="STORAGE RESERVE LIFECYCLE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="500" y="20" width="800" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Maintain one ready same-LAN standby SECONDARY per LAN — activate on load/recovery, replenish immediately. Feature gate: STORAGE_PERSISTENT_RESERVE_ENABLED" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="150" y="56" width="1500" height="22" as="geometry"/>
                </mxCell>
                <!-- Phase headers -->
                <mxCell id="ph1" value="1 · PREPARE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="120" y="100" width="220" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="ph2" value="2 · SPAWN (standby)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="360" y="100" width="260" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="ph3" value="3 · READY (reserved)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="640" y="100" width="260" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="ph4" value="4 · ACTIVATE (load / recovery)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="920" y="100" width="340" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="ph5" value="5 · REPLENISH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="100" width="220" height="30" as="geometry"/>
                </mxCell>
                <!-- Phase separators -->
